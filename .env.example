# MongoDB Connection
MONGODB_URI=mongodb://127.0.0.1:27017/dulceria

# Seguridad endpoint de compañera
COMPANERA_API_KEY=cambia-esta-clave

# CORS (separa por comas cuando uses frontend y backend en dominios distintos)
# Ejemplo: CORS_ORIGIN=https://tuusuario.github.io,https://tu-app.vercel.app
CORS_ORIGIN=

# Backup automático al escribir datos (POST/PUT/PATCH/DELETE)
BACKUP_ON_WRITE=true
BACKUP_DIR=./backups
BACKUP_DEBOUNCE_MS=2000
BACKUP_KEEP_FILES=80

# Server Port
PORT=3000
